<%= turbo_stream.append "modal-container" do %>
  <%# --- モーダル全体 --- %>
  <div class="fixed inset-0 z-50 flex items-center justify-center p-0 sm:p-6 transition-opacity duration-300" 
    data-controller="modal">

    <%# 背景 %>
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"
      data-action="click->modal#close">
    </div>

    <%# --- モーダル本体 --- %>
    <div class="relative flex h-[100dvh] sm:h-auto sm:max-h-[85vh] w-full max-w-2xl flex-col overflow-hidden sm:rounded-xl bg-white shadow-2xl animate-fade-in-up transition-all duration-300"
      data-modal-target="modalBox">

      <%# ヘッダー %>
      <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 bg-white z-10">
        <h2 class="text-xl font-bold text-gray-800">お問い合わせ</h2>
        <button type="button" class="rounded-full p-2 text-gray-400 hover:bg-gray-100 hover:text-gray-600 transition"
                data-action="click->modal#close">
          <%= lucide_icon('x', class: "w-6 h-6") %>
        </button>
      </div>

      <%# コンテンツエリア %>
      <div class="flex-1 overflow-y-auto px-6 py-4 text-sm leading-relaxed text-gray-600">
        <div class="space-y-2">

          <div class="mx-auto max-w-2xl px-4 py-0">

            <p class="leading-7 text-gray-700">
              シロイチズに関するご質問、不具合報告、削除依頼などは、
              以下のフォームからお問い合わせください。
            </p>

            <p class="mt-2 pb-0 text-sm leading-6 text-gray-600">
              削除依頼を受けた場合、内容を確認のうえ、運営者の判断により対象の投稿を削除または非公開化することがあります。
              本人確認が困難な場合でも、公開による不利益が大きいと判断した場合は、一時的に非公開化することがあります。
            </p>

            <p class="mt-2 pb-4 text-sm leading-6 text-gray-600">
              内容によっては返信できない場合があります。あらかじめご了承ください。
            </p>

            <%= form_with url: contact_path, method: :post, data: { turbo_stream: true } do |f| %>
              <div class="space-y-5">
                <div>
                  <%= f.label :subject, "件名", class: "block text-sm font-bold mb-2" %>
                  <%= f.text_field :subject,
                        maxlength: 100,
                        required: true,
                        class: "w-full rounded-xl border px-3 py-2" %>
                </div>

                <div>
                  <%= f.label :body, "本文", class: "block text-sm font-bold mb-2" %>
                  <%= f.text_area :body,
                        maxlength: 2000,
                        required: true,
                        rows: 8,
                        class: "w-full rounded-xl border px-3 py-2" %>
                </div>

                <%= f.submit "送信する",
                      class: "w-full rounded-xl bg-black px-5 py-3 text-white font-bold" %>
              </div>
            <% end %>

          </div>

        </div>
      </div>

      <%# フッター %>
      <div class="border-t border-gray-100 bg-gray-50 px-6 py-4 flex justify-end">
        <button type="button"
                class="rounded-lg bg-gray-800 px-6 py-2.5 text-sm font-medium text-white shadow hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition"
                data-action="click->modal#close">
          閉じる
        </button>
      </div>

    </div>
  </div>
<% end %>
