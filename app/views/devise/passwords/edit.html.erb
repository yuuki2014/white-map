<%# パスワード再設定ページ %>
<%# ヘッダー %>
<% content_for :header do %>
  <%= render 'shared/header', back_path: new_session_path(resource_name), title: "パスワード再設定", bg_color: "bg-orange-300" %>
<% end %>

<%# メインコンテナ %>
<div class="h-full bg-[#FFFBE6] flex flex-col items-center px-6 pb-10 font-sans text-gray-800">

  <%# ロゴエリア %>
  <div class="mt-8 pt-4 pb-4 w-full flex justify-center">
    <div class="size-40 rounded flex items-center justify-center">
      <%= image_tag "logo-vertical.svg" %>
    </div>
  </div>

  <%# 案内テキストエリア %>
  <div class="w-full max-w-sm mb-6 text-center px-2">
    <div class="text-lg font-bold text-gray-800 mb-2">新しいパスワードの設定</div>
    <div class="text-sm text-gray-600 leading-relaxed">新しいパスワードを入力してください。</div>
  </div>

  <%# フォームエリア %>
  <div class="w-full max-w-sm">
    <%= form_with(model: resource, url: password_path(resource_name), method: :put, class: "space-y-6") do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <%# パスワード %>
      <div class="field">
        <div class="flex items-center mb-2 gap-3">
          <%= f.label :password, "新しいパスワード", class: "text-sm font-bold" %>

          <% if @minimum_password_length %>
            <span class="text-xs text-gray-400">
              ※ <%= @minimum_password_length %>文字以上
            </span>
          <% end %>
        </div>

        <div class="relative">
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••••••••••", autofocus: true,
              class: "w-full px-4 py-3 rounded-xl border-none shadow-sm text-gray-700 placeholder-gray-400 focus:ring-2 focus:ring-orange-300 outline-none tracking-widest" %>

          <%# 目のアイコン（見た目のみ） %>
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer text-gray-500">
            <%= lucide_icon('eye', class: "w-6 h-6") %>
          </div>
        </div>
      </div>

      <%# パスワード確認 %>
      <div class="field">
        <%= f.label :password_confirmation, "新しいパスワード(確認用)", class: "block text-sm font-bold mb-2" %>

        <div class="relative">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••••••••••",
              class: "w-full px-4 py-3 rounded-xl border-none shadow-sm text-gray-700 placeholder-gray-400 focus:ring-2 focus:ring-orange-300 outline-none tracking-widest" %>

          <%# 目のアイコン（見た目のみ） %>
          <div class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer text-gray-500">
            <%= lucide_icon('eye', class: "w-6 h-6") %>
          </div>
        </div>
      </div>

      <%# ボタンエリア %>
      <div class="flex flex-col items-center pt-4">
        <%# 送信ボタン %>
        <%= f.submit "パスワードを変更する", class: "w-full max-w-[240px] bg-orange-400 hover:bg-orange-500 text-white font-bold py-3 px-6 rounded-full shadow-md cursor-pointer transition text-center" %>
      </div>

    <% end %>
  </div>
</div>
