<%# 各データをループ表示 %>
<% if trips.present? %>
  <% trips.each do |trip| %>
    <% geohash_count = geohash_counts[trip.id] || 0 %>

    <%# --- 地図全体コンテナ --- %>
    <%= turbo_frame_tag dom_id(trip), class: "block border-b border-gray-300 last:border-none" do %>
      <div
        class="py-4 px-2 max-w-2xl mx-auto hover:bg-[#fff5e6] transition-colors duration-200 cursor-pointer"
        data-controller="clickable-card"
        data-action="click->clickable-card#open">

        <%# カード全体をクリック可能にするリンク %>
        <%= link_to "", trip_path(trip), class: "hidden", data: { turbo_frame: "_top", clickable_card_target: "link" } %>

        <div class="flex gap-3">
          <%# --- 左カラム: アイコン --- %>
          <div class="shrink-0">
            <% if trip.user&.avatar&.attached? %>
              <%= image_tag avatar_url(trip.user), class: "w-10 h-10 object-cover rounded-full shadow-sm" %>
            <% else %>
              <div class="w-10 h-10 bg-orange-400 rounded-full flex items-center justify-center shadow-sm">
                <%= lucide_icon('user-round', class: "w-9 h-9 text-white") %>
              </div>
            <% end %>
          </div>

          <%# --- 右カラム: メインコンテンツ --- %>
          <div class="flex-1 min-w-0">

            <%# --- ヘッダー (ユーザー名, 日時) --- %>
            <div class="flex items-start justify-between">
              <div class="flex items-baseline gap-1.5 truncate pr-2 mt-0.5">
                <span class="font-bold text-[13px] text-gray-900 truncate">
                  <%= trip.user&.nickname || "" %>
                </span>
              </div>

              <div class="flex gap-3">
                <span class="text-xs text-gray-500 whitespace-nowrap">
                  <%= trip.started_at&.strftime("%Y/%m/%d %H:%M") %>
                </span>
                <%# 三点リーダボタン %>
                <div class="relative shrink-0 -mt-1 -mr-2">
                  <%= link_to bottom_sheets_path(trip), class: "h-8 w-8 flex items-center justify-center text-gray-400 hover:text-blue-500 hover:bg-blue-50 rounded-full transition", data: { turbo_stream: true } do %>
                    <%= lucide_icon('ellipsis', class: "w-5 h-5") %>
                  <% end %>
                </div>
              </div>
            </div>

            <%# --- タイトル --- %>
            <div class="mt-1 text-[15px] font-bold text-gray-900 leading-snug truncate">
              <%= trip.title %>
            </div>

            <%# --- 地図画像コンテナ --- %>
            <div class="mt-3 w-full overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm aspect-video relative">
              <%# <%= image_tag , class: "absolute inset-0 w-full h-full object-cover" %>

              <%# ダミーのプレースホルダー %>
              <div class="absolute inset-0 flex flex-col items-center justify-center bg-gray-50 text-gray-400">
                <%#= image_tag "#{request.base_url}/ogp.png" %>
                <%= lucide_icon('map', class: "w-8 h-8 mb-1 text-gray-300") %>
                <span class="text-xs font-medium tracking-wider">MAP IMAGE</span>
              </div>
            </div>

            <%# --- 詳細データ (距離・時間) --- %>
            <div class="mt-3 flex flex-wrap items-center gap-3 text-[13px] font-medium">
              <div class="flex items-center gap-1.5 bg-stone-100 text-stone-700 px-2.5 py-1 rounded-md border border-stone-200">
                <%= lucide_icon('route', class: "w-4 h-4 text-orange-500") %>
                <span><%= trip.total_distance %> m / <%= geohash_count %> マス</span>
              </div>

              <div class="flex items-center gap-1.5 bg-stone-100 text-stone-700 px-2.5 py-1 rounded-md border border-stone-200">
                <%= lucide_icon('clock', class: "w-4 h-4 text-orange-500") %>
                <span><%= format_duration(trip.activity_time) %></span>
              </div>
            </div>

          </div>
        </div>
      </div>
    <% end %>
  <% end %>
<% else %>
  <%# 空状態 %>
  <div class="flex flex-col items-center justify-center py-12 text-gray-500 border-b border-gray-200 max-w-2xl mx-auto">
    <%= lucide_icon('map', class: "w-10 h-10 mb-3 text-gray-300") %>
    <p class="text-sm">地図が存在しません。</p>
  </div>
<% end %>
