<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "シロイチズ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "歩いた場所が記録され、地図が少しずつ埋まっていく。探索が楽しくなる散歩アプリ"%>">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# googleフォント %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c&family=Noto+Sans+JP:wght@100..900&display=swap" rel="stylesheet">

    <link rel="manifest" href="/manifest.json">

    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png">
    <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# OGP %>
    <meta property="og:title" content="<%= content_for(:title) || "シロイチズ" %>">
    <meta property="og:description" content="<%= content_for(:description) || "歩いた場所が記録され、地図が少しずつ埋まっていく。探索が楽しくなる散歩アプリ" %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:site_name" content="シロイチズ">
    <meta property="og:locale" content="ja_JP">
    <meta property="og:image" content="<%= image_url("ogp.png") %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="シロイチズのOGP画像">

    <%# X(Twitter) Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for(:title) || "シロイチズ" %>">
    <meta name="twitter:description" content="<%= content_for(:description) || "歩いた場所が記録され、地図が少しずつ埋まっていく。探索が楽しくなる散歩アプリ" %>">
    <meta name="twitter:image" content="<%= image_url("ogp.png") %>">

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "my_style", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body id="ui" class="h-dvh w-full flex flex-col overflow-hidden" data-controller="ui" data-ui-map-outlet="#main-map" data-ui-history-map-outlet="#history-map">
    <div class="fixed inset-0 z-50 hidden" data-ui-target="uiOverlay" data-action="click->ui#clearUiOverlay"></div>
    <%= yield :header %>
    <main class="flex-1 relative overflow-y-auto font-sans">
      <%= yield %>
    </main>
    <% if show_footer? %>
      <%= render "shared/footer" %>
    <% end %>
    <%= render "bottom_sheets/bottom_sheets_shell" %>
    <%= render "shared/modal_shell" %>

    <div id="notification-container" class="fixed top-6 left-1/2 -translate-x-1/2 z-50 flex flex-col items-center gap-2 pointer-events-none w-full max-w-[90vw]">
      <div id="flash" class="flex flex-col items-center gap-2 w-full">
        <%= render "shared/flash_message" %>
      </div>
      <div id="error-container" class="flex flex-col items-center gap-2 w-full">
        <%= render "shared/error_messages" %>
      </div>
    </div>

  </body>
</html>
