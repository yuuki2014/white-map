<%= turbo_stream.append "modal-container" do %>
  <%# モーダルの全体枠 %>
  <div class="fixed inset-0 h-full w-full pointer-events-none z-40 flex justify-center items-center opacity-0 transition-all duration-300 p-0" data-controller="modal">

    <%# --- バックドロップ --- %>
    <div class="modal-backdrop absolute inset-0 bg-black/50 z-0 pointer-events-auto" data-modal-target="modalBackdrop" data-action="click->modal#close"></div>

    <%# モーダル枠 (Swiper本体): 余計なflexクラスを外して w-full h-full に専念させる %>
    <div data-controller="image-viewer"
          data-image-viewer-initial-slide-value="<%= params[:index].to_i %>"
          class="swiper absolute inset-0 w-full h-full pointer-events-auto z-10 transition-all duration-500 ease-out translate-y-40 opacity-0" data-modal-target="modalBox">

      <%# --- 右上のバツボタン --- %>
      <button class="absolute right-1 top-1 sm:right-1 sm:top-1 h-10 w-10 flex items-center justify-center leading-none bg-gray-500/50 hover:bg-gray-600/60 text-white rounded-full z-30 transition" data-action="click->modal#close">
        <%= lucide_icon('x', class: "w-6 h-6") %>
      </button>

      <div class="swiper-wrapper h-full w-full">

        <% @post.images.each do |image| %>

          <div class="swiper-slide relative h-full w-full">
            <div class="swiper-zoom-container">
              <%= image_tag image, loading: "lazy", class: "max-w-full max-h-full object-contain" %>
            </div>
          </div>

        <% end %>

      </div>

      <div class="absolute bottom-3 left-1/2 transform -translate-x-1/2 flex items-center justify-center gap-6 z-30 w-full pointer-events-none">

        <button class="custom-button-prev hidden sm:flex items-center justify-center w-12 h-12 rounded-full border-2 border-white bg-black/50 hover:bg-black/80 text-white transition cursor-pointer pointer-events-auto">
          <%= lucide_icon('chevron-left', class: "w-6 h-6") %>
        </button>

        <%# <div class="swiper-pagination !relative !bottom-0 !w-auto !text-black font-black pointer-events-none [-webkit-text-stroke:1px_#fff] text-xl"></div> %>

        <button class="custom-button-next hidden sm:flex items-center justify-center w-12 h-12 rounded-full border-2 border-white bg-black/50 hover:bg-black/80 text-white transition cursor-pointer pointer-events-auto">
          <%= lucide_icon('chevron-right', class: "w-6 h-6") %>
        </button>

      </div>

    </div>

  </div>
<% end %>
